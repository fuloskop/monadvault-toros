# TOROS Games Backend (forked from MonadVault) — .env example
# Bu dosya .env.example, gerçek değerler .env içinde olmalı (gitignored).

# === Database (MySQL) ===
# Task 32: PostgreSQL → MySQL port edildi. Toroscs ana DB'sinden ayrı bir
# schema (games) kullanıyoruz, ama aynı MySQL instance'ında olabilir.
DATABASE_URL="mysql://user:password@localhost:3306/toros_games"

# === Redis ===
REDIS_URL="redis://localhost:6379"

# === Session (iron-session cookie reader, TOROS shared) ===
# Bu secret toroscs'taki SESSION_SECRET ile BİREBİR AYNI olmalı — aynı cookie
# (toroscs_session) her iki app tarafından decrypt edilebiliyor.
SESSION_SECRET="must-be-the-same-as-toroscs-SESSION_SECRET-here"

# === Admin ===
# Virgülle ayrılmış SteamID listesi. Bu kullanıcılar /admin'e erişebilir.
ADMIN_STEAM_IDS=""

# === Frontend URL (CORS) ===
# Production'da torosclan.com olacak. Aynı domain altında olduğumuz için
# CORS aslında devreye girmiyor — dev için lazım.
FRONTEND_URL="http://localhost:3000"

# === Legacy JWT (web3 disable edildi, fallback için yerinde) ===
JWT_SECRET="not-used-in-toros-fork-but-keep-for-upstream-compat"
JWT_EXPIRY="7d"

# === Server ===
PORT=4000
NODE_ENV="development"

# TOROS Games Frontend (forked from MonadVault) — .env example

# Backend API URL — aynı domain altında çalıştığımız için relative bırakıyoruz
# (basePath /games sayesinde /games/api/... olur). Dev'de backend ayrı portta
# ise (örn. localhost:4000), buraya tam URL yaz.
NEXT_PUBLIC_API_URL=""

# Socket.io URL — yine aynı domain için boş. Dev'de tam URL ver.
NEXT_PUBLIC_WS_URL=""

# basePath override — production'da '/games' (default). Dev'de '/' istersen "".
NEXT_PUBLIC_BASE_PATH="/games"

# === Web3 (TOROS fork'ta default kapalı) ===
# Wallet connect UI ve wagmi katmanını açmak için 'true' yap. Default kapalı;
# auth toroscs iron-session cookie'siyle akıyor.
NEXT_PUBLIC_WEB3_ENABLED="false"
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""
